rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Collection: members
    match /members/{memberId} {
      allow read: if true;
      allow create, update: if isValidId(memberId) &&
        incoming().id is string && incoming().id.size() <= 100 &&
        incoming().name is string && incoming().name.size() <= 100 &&
        incoming().phone is string && incoming().phone.size() <= 100;
      allow delete: if true;
    }

    // Collection: cabinet
    match /cabinet/{cabinetId} {
      allow read: if true;
      allow create, update: if isValidId(cabinetId) &&
        incoming().name is string && incoming().name.size() <= 100 &&
        incoming().role is string && incoming().role.size() <= 100;
      allow delete: if true;
    }

    // Collection: reports
    match /reports/{reportId} {
      allow read: if true;
      allow create, update: if isValidId(reportId) &&
        incoming().reporterName is string && incoming().reporterName.size() <= 100 &&
        incoming().details is string && incoming().details.size() <= 1000;
      allow delete: if true;
    }

    // Collection: donations
    match /donations/{donationId} {
      allow read: if true;
      allow create, update: if isValidId(donationId) &&
        incoming().donorName is string && incoming().donorName.size() <= 100 &&
        incoming().amount is number;
      allow delete: if true;
    }

    // Collection: lawArticles
    match /lawArticles/{lawId} {
      allow read: if true;
      allow create, update: if isValidId(lawId) &&
        incoming().title is string && incoming().title.size() <= 200 &&
        incoming().content is string && incoming().content.size() <= 5000;
      allow delete: if true;
    }

    // Collection: candidates
    match /candidates/{candidateId} {
      allow read: if true;
      allow create, update: if isValidId(candidateId) &&
        incoming().name is string && incoming().name.size() <= 100 &&
        incoming().votes is number;
      allow delete: if true;
    }

    // Collection: pressReleases
    match /pressReleases/{releaseId} {
      allow read: if true;
      allow create, update: if isValidId(releaseId) &&
        incoming().title is string && incoming().title.size() <= 200 &&
        incoming().content is string && incoming().content.size() <= 5000;
      allow delete: if true;
    }

    // Collection: announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update: if isValidId(announcementId) &&
        incoming().text is string && incoming().text.size() <= 500;
      allow delete: if true;
    }
  }
}
